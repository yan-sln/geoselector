{
  "base_url": "https://data.geopf.fr/wfs/ows",
  "api_type": "wfs",
  "common": {
    "SERVICE": "WFS",
    "VERSION": "2.0.0",
    "REQUEST": "GetFeature",
    "OUTPUTFORMAT": "application/json"
  },
  "entities": {
    "region": {
      "TYPENAME": "LIMITES_ADMINISTRATIVES_EXPRESS.LATEST:region",
      "search_by_name": {
        "PROPERTYNAME": "nom_officiel,code_insee",
        "CQL_FILTER": "nom_officiel='{value}'"
      },
      "search_by_code": {
        "PROPERTYNAME": "nom_officiel,code_insee",
        "CQL_FILTER": "code_insee='{value}'"
      },
      "geometry": {
        "PROPERTYNAME": "geometrie",
        "CQL_FILTER": "code_insee='{value}'"
      }
    },
    "departement": {
      "TYPENAME": "LIMITES_ADMINISTRATIVES_EXPRESS.LATEST:departement",
      "search_by_name": {
        "PROPERTYNAME": "nom_officiel,code_insee",
        "CQL_FILTER": "nom_officiel='{value}'"
      },
      "search_by_code": {
        "PROPERTYNAME": "nom_officiel,code_insee",
        "CQL_FILTER": "code_insee='{value}'"
      },
      "geometry": {
        "PROPERTYNAME": "geometrie",
        "CQL_FILTER": "code_insee='{value}'"
      }
    },
    "commune": {
      "TYPENAME": "CADASTRALPARCELS.PARCELLAIRE_EXPRESS:commune",
      "search_by_name": {
        "PROPERTYNAME": "code_insee,nom_com",
        "CQL_FILTER": "nom_com='{value}'"
      },
      "search_by_code": {
        "PROPERTYNAME": "code_insee,nom_com",
        "CQL_FILTER": "code_insee='{value}'"
      },
      "geometry": {
        "PROPERTYNAME": "geom",
        "CQL_FILTER": "code_insee='{value}'"
      }
    },
    "arrondissement": {
      "TYPENAME": "CADASTRALPARCELS.PARCELLAIRE_EXPRESS:arrondissement",
      "search_by_code": {
        "PROPERTYNAME": "code_insee,nom_arr,code_arr",
        "CQL_FILTER": "code_insee='{value}'"
      },
      "geometry": {
        "PROPERTYNAME": "geom",
        "CQL_FILTER": "code_insee='{value}'"
      }
    },
    "feuille": {
      "TYPENAME": "CADASTRALPARCELS.PARCELLAIRE_EXPRESS:feuille",
      "search": {
        "PROPERTYNAME": "code_insee,section,feuille",
        "CQL_FILTER": "code_insee='{code_insee}' AND section='{section}'"
      },
      "geometry": {
        "PROPERTYNAME": "geom",
        "CQL_FILTER": "code_insee='{code_insee}' AND section='{section}' AND feuille='{feuille}'"
      },
      "list_sections": {
        "PROPERTYNAME": "section",
        "CQL_FILTER": "code_insee='{code_insee}'",
        "DISTINCT": "property:section"
      }
    },
    "parcelle": {
      "TYPENAME": "CADASTRALPARCELS.PARCELLAIRE_EXPRESS:parcelle",
      "search": {
        "PROPERTYNAME": "code_insee,section,numero,idu",
        "CQL_FILTER": "code_insee='{code_insee}' AND section='{section}'"
      },
      "geometry": {
        "PROPERTYNAME": "geom",
        "featureId": "{feature_id}",
        "CQL_FILTER": null
      }
    },
    "subdivision_fiscale": {
      "TYPENAME": "CADASTRALPARCELS.PARCELLAIRE_EXPRESS:subdivision_fiscale",
      "search": {
        "PROPERTYNAME": "gid,idu_parcel,lettre",
        "CQL_FILTER": "idu_parcel='{idu_parcel}'"
      },
      "geometry": {
        "PROPERTYNAME": "geom",
        "CQL_FILTER": "idu_parcel='{idu_parcel}'"
      }
    }
  }
}
